  "keyFeatures": [
    "User authentication with social login (Google)",
    "Property listing and management with images and maps",
    "Digital rental contracts with PDF generation",
    "Automated monthly payment tracking with late fees",
    "Property reviews and ratings system",
    "Favorites/wishlist for properties",
    "AI chatbot assistant (Arrendito) powered by Gemini 2.0",
    "Admin dashboard with reports and analytics",
    "Role-based access control (Tenant, Landlord, Admin)",
    "RESTful API with Laravel Sanctum authentication",
    "Excel and PDF export for financial statements",
    "Notification system for payments and events",
    "Calendar integration for rental events"
  ],
  "publicApiSurface": [
    "POST /api/login - User authentication",
    "POST /api/register - User registration",
    "GET /api/inmuebles/public-list - List available properties",
    "GET /api/inmuebles/public-detail/{id} - Property details",
    "POST /api/inmuebles - Create property (auth)",
    "PUT /api/inmuebles/{id} - Update property (auth)",
    "DELETE /api/inmuebles/{id} - Delete property (auth)",
    "GET /api/contratos - List user contracts (auth)",
    "POST /api/inmuebles/{id}/rentar - Create rental contract (auth)",
    "GET /api/contratos/{id}/estado-cuenta - Financial statement (auth)",
    "GET /api/pagos/pendientes - List pending payments (auth)",
    "POST /api/pagos/{id}/pagar - Process payment (auth)",
    "POST /api/inmuebles/{id}/resenas - Create review (auth)",
    "GET /api/favoritos - List favorites (auth)",
    "POST /api/favoritos/{id}/toggle - Toggle favorite (auth)",
    "POST /api/arrendito/chat - Chat with AI assistant",
    "GET /api/reportes/ingresos - Revenue reports (auth)"
  ]
}
